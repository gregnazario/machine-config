# === Multi-stage Build Optimization ===

# Use specific base images
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY . .
RUN npm run build

# Production stage
FROM node:20-alpine AS production
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY package*.json ./
EXPOSE 3000
CMD ["npm", "start"]

# === Docker Buildx (Multi-platform) ===

# Create builder
# docker buildx create --name mybuilder --use

# Build for multiple platforms
# docker buildx build --platform linux/amd64,linux/arm64 -t myimage:latest .

# === Registry Configuration ===

# Login to registries
# docker login ghcr.io
# docker login registry.gitlab.com

# Tag for registry
# docker tag myimage:latest ghcr.io/username/myimage:latest

# Push to registry
# docker push ghcr.io/username/myimage:latest

# === Notes ===

# 1. Use .dockerignore to reduce build context size
# 2. Use multi-stage builds to reduce final image size
# 3. Tag images with version and commit hash
# 4. Use BuildKit for better build performance
# 5. Use specific version tags (not 'latest') in production
# 6. Set resource limits on containers
# 7. Use health checks for long-running services
# 8. Use volumes for persistent data
# 9. Use networks for service isolation
# 10. Use secrets for sensitive data (swarm mode)
