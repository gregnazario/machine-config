# === Project-Specific Versions ===
# These can be overridden per-project

# For most projects, use system-default versions:
# python latest
# nodejs lts

# For projects requiring specific versions:
# python 3.11.7
# nodejs 20.11.0

# === ASDF Configuration ===
# ~/.asdfrc

# [defaults]
# # Plugin repository
# plugin_repository_url = https://github.com/asdf-vm/asdf-plugins.git

# # Load plugins installed in home directory
# # (as opposed to system-wide)
# use_release_candidates = false

# # Legacy version files support
# # (e.g., .nvmrc, .node-version)
# legacy_version_file = yes

# # Plugins to not load
# # (useful if you have many plugins)
# # excluded_plugins = []

# # Disable short hand for plugin version
# # (e.g., asdf install python latest)
# # allow_plugin_shortname = true

# # Verify checksums when downloading
# # verify_checksums = true

# # Use GPG verification
# # use_gpg_verification = true

# === ASDF Common shims ===
# When using asdf, shims are created in ~/.asdf/shims/
# These shim scripts redirect to the appropriate tool version

# To see all installed tools:
# asdf list

# To see all installed versions of a tool:
# asdf list python

# To set global (default) version:
# asdf global python 3.11.7

# To set local (project) version:
# asdf local python 3.11.7

# To install a new version:
# asdf install python 3.11.7

# To install all tools defined in .tool-versions:
# asdf install

# === ASDF Plugins ===
# List all installed plugins:
# asdf plugin list

# Add a new plugin:
# asdf plugin add python
# asdf plugin add nodejs
# asdf plugin add rust

# Update all plugins:
# asdf plugin-update --all

