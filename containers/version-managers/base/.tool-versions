# === Bun as Primary Runtime ===
# Configuration for Bun-first Node.js projects

# For Bun projects, use this .tool-versions:
# nodejs 18.18.0  # Bun 1.x requires Node 18+
# bun 1.0.25

# Then use bun instead of npm/yarn/pnpm:
# bun install
# bun run build
# bun test

# Bun can also install Node.js packages directly:
# bun add <package>
# bun remove <package>

# === Version Aliases ===
# ASDF supports version aliases in .tool-versions

# Use 'latest' to always use the latest version:
# python latest

# Use 'lts' for Node.js LTS:
# nodejs lts

# Or pin to specific LTS version:
# nodejs lts-iron

# Use ':path' for local version:
# python system:/usr/bin/python3.11

# === Shell Integration ===
# Add to your shell config (.zshrc, .bashrc, config.fish):

# For Bash:
# . "$HOME/.asdf/asdf.sh"
# . "$HOME/.asdf/completions/asdf.bash"

# For Zsh:
# . "$HOME/.asdf/asdf.sh"
# fpath=(${ASDF_DIR}/completions $fpath)
# autoload -Uz compinit && compinit

# For Fish:
# source "$HOME/.asdf/asdf.fish"
# mkdir -p ~/.config/fish/completions
# and ln -s ~/.asdf/completions/asdf.fish ~/.config/fish/completions/asdf.fish

# === Notes ===
# 1. The .tool-versions file should be committed to version control
# 2. Use specific versions for reproducibility
# 3. Use 'latest' only for development/experimental projects
# 4. Pin major versions (e.g., 3.11) for better compatibility
# 5. ASDF reads .tool-versions from current directory and parent directories
# 6. Global default can be set in ~/.tool-versions
# 7. Project-specific .tool-versions override global versions
# 8. Use 'asdf reshim python' after installing packages globally
