# ShellCheck configuration
# https://www.shellcheck.net/wiki/SC2164

# Include sourced files in checks
include-extracted=

# Follow sourced files
external-sources=true

# Disable specific warnings globally
# Some warnings may need to be disabled for compatibility

# SC2039: In POSIX sh, 'local' is undefined
# Most modern sh support 'local', so we allow it
disable=SC2039

# SC2034: Variable appears unused (may be used in sourced scripts)
disable=SC2034

# SC1090: Can't follow non-constant source
# Use a directive if it's problematic
# disable=SC1090

# SC2164: Use 'cd ... || exit' instead of 'cd ...'
# disable=SC2164

# SC2154: Variable is referenced but not assigned
# disable=SC2154

# SC2181: Check exit code directly with e.g. 'if mycmd;', not with 'if [ $? -ne 0 ]'
# disable=SC2181

# Make exceptions for specific files
# exclude-dir=[pattern]
exclude-dir=.git
exclude-dir=node_modules

# Set shell dialect
shell=sh

# Severity (error, warning, info, style)
severity=style
